{
  "custom": {
    "selectedTickerSafe": "AAPL"
  },
  "params": {},
  "props": {
    "defaultSize": {
      "height": 1500,
      "width": 1600
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Title"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "text": "STOCK DASHBOARD",
              "style": {
                "color": "#f0f6fc",
                "fontSize": "18px",
                "fontWeight": "bold",
                "letterSpacing": "3px",
                "fontFamily": "Consolas, monospace"
              }
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "SelectLabel"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "text": "SELECT STOCK:",
                  "style": {
                    "color": "#8b949e",
                    "fontSize": "11px",
                    "marginRight": "10px",
                    "fontFamily": "Consolas, monospace"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "StockDropdown"
                },
                "position": {
                  "basis": "200px",
                  "shrink": 0
                },
                "propConfig": {
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.selectedTickerSafe"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "options": [
                    {"label": "AAPL — Apple", "value": "AAPL"},
                    {"label": "NVDA — Nvidia", "value": "NVDA"},
                    {"label": "TSLA — Tesla", "value": "TSLA"},
                    {"label": "MSFT — Microsoft", "value": "MSFT"},
                    {"label": "AMZN — Amazon", "value": "AMZN"},
                    {"label": "META — Meta", "value": "META"},
                    {"label": "PLTR — Palantir", "value": "PLTR"},
                    {"label": "SOFI — SoFi Tech", "value": "SOFI"},
                    {"label": "AMD — AMD", "value": "AMD"},
                    {"label": "MA — Mastercard", "value": "MA"},
                    {"label": "MCD — McDonald's", "value": "MCD"},
                    {"label": "TD.TO — TD Bank", "value": "TD_TO"},
                    {"label": "ENB.TO — Enbridge", "value": "ENB_TO"},
                    {"label": "GOOGL — Alphabet", "value": "GOOGL"}
                  ],
                  "search": {"enabled": false}
                },
                "type": "ia.input.dropdown"
              }
            ],
            "meta": {
              "name": "SelectorGroup"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "align": "center",
              "justify": "center",
              "style": {}
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "LastUpdated"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"UPDATED: \" + tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/last_updated\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "text": "UPDATED: --",
              "style": {
                "color": "#8b949e",
                "fontSize": "11px",
                "fontFamily": "Consolas, monospace"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "58px",
          "shrink": 0
        },
        "props": {
          "align": "center",
          "justify": "space-between",
          "style": {
            "backgroundColor": "#161b22",
            "borderBottom": "1px solid #30363d",
            "paddingLeft": "24px",
            "paddingRight": "24px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "TickerName"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "expression": "replace({view.custom.selectedTickerSafe}, \"_TO\", \".TO\")"
                          },
                          "type": "expr"
                        }
                      }
                    },
                    "props": {
                      "text": "AAPL",
                      "style": {
                        "color": "#f0f6fc",
                        "fontSize": "20px",
                        "fontWeight": "bold",
                        "marginRight": "20px",
                        "fontFamily": "Consolas, monospace"
                      }
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "Price"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "expression": "toStr(round(tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/price\"), 2))"
                          },
                          "type": "expr"
                        }
                      }
                    },
                    "props": {
                      "text": "---",
                      "style": {
                        "color": "#f0f6fc",
                        "fontSize": "30px",
                        "fontWeight": "bold",
                        "marginRight": "10px",
                        "fontFamily": "Consolas, monospace"
                      }
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "Currency"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "expression": "tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/currency\")"
                          },
                          "type": "expr"
                        }
                      }
                    },
                    "props": {
                      "text": "USD",
                      "style": {
                        "color": "#8b949e",
                        "fontSize": "13px",
                        "marginRight": "20px",
                        "fontFamily": "Consolas, monospace",
                        "alignSelf": "flex-end",
                        "paddingBottom": "4px"
                      }
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "Change"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "expression": "toStr(round(tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/change_pct\"), 2)) + \"%\""
                          },
                          "type": "expr"
                        }
                      },
                      "props.style.color": {
                        "binding": {
                          "config": {
                            "expression": "tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/change_pct\")"
                          },
                          "transforms": [
                            {
                              "expression": "if({value} >= 0, '#3fb950', '#f85149')",
                              "type": "expression"
                            }
                          ],
                          "type": "expr"
                        }
                      }
                    },
                    "props": {
                      "text": "0.00%",
                      "style": {
                        "fontSize": "20px",
                        "fontWeight": "bold",
                        "fontFamily": "Consolas, monospace",
                        "alignSelf": "flex-end",
                        "paddingBottom": "2px"
                      }
                    },
                    "type": "ia.display.label"
                  }
                ],
                "meta": {
                  "name": "TickerPriceGroup"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "align": "baseline",
                  "style": {}
                },
                "type": "ia.container.flex"
              },
              {
                "meta": {
                  "name": "SignalText"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/signal_text\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.style.color": {
                    "binding": {
                      "config": {
                        "expression": "tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/signal_int\")"
                      },
                      "transforms": [
                        {
                          "expression": "if({value} = 2, '#3fb950', if({value} = 1, '#7cb342', if({value} = 0, '#ffd600', if({value} = -1, '#ff8c00', '#f85149'))))",
                          "type": "expression"
                        }
                      ],
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "text": "HOLD",
                  "style": {
                    "fontSize": "22px",
                    "fontWeight": "bold",
                    "letterSpacing": "2px",
                    "fontFamily": "Consolas, monospace"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "SignalBanner"
            },
            "position": {
              "basis": "64px",
              "shrink": 0
            },
            "propConfig": {
              "props.style.backgroundColor": {
                "binding": {
                  "config": {
                    "expression": "tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/signal_int\")"
                  },
                  "transforms": [
                    {
                      "expression": "if({value} = 2, '#0d2818', if({value} = 1, '#1c3a10', if({value} = 0, '#2d2200', if({value} = -1, '#3a1800', '#2d0d0d'))))",
                      "type": "expression"
                    }
                  ],
                  "type": "expr"
                }
              }
            },
            "props": {
              "align": "center",
              "justify": "space-between",
              "style": {
                "borderBottom": "1px solid #30363d",
                "paddingLeft": "24px",
                "paddingRight": "24px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {"name": "RSILabel"},
                    "position": {"shrink": 0},
                    "props": {"text": "RSI (14)", "style": {"color": "#8b949e", "fontSize": "11px", "fontFamily": "Consolas, monospace", "marginBottom": "6px"}},
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {"name": "RSIValue"},
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {"expression": "toStr(round(tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/rsi\"), 1))"},
