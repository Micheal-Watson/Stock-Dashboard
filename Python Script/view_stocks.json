                      "props.style.color": {
                        "binding": {
                          "config": {"expression": "tag(\"[StockData]Stocks/\" + {view.custom.selectedTickerSafe} + \"/rsi\")"},
                          "transforms": [{"expression": "if({value} < 30, '#3fb950', if({value} > 70, '#f85149', '#f0f6fc'))", "type": "expression"}],
                          "type": "expr"
                        }
                      }
                    },
                    "props": {"text": "...", "style": {"fontSize": "26px", "fontWeight": "bold", "fontFamily": "Consolas, monospace"}},
